# =========================================
# APP
# =========================================
APP_NAME=Enterprise LLM Wiki
# Use "production" in production — enables JSON logging and stricter checks
APP_ENV=development
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080
API_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000
# SECURITY: Change to your real frontend domain in production, e.g.:
#   ALLOW_ORIGINS=https://wiki.mycompany.com
ALLOW_ORIGINS=*

# =========================================
# SUPABASE CLOUD
# =========================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# WARNING: This is the service_role key — never expose to the browser or frontend
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SCHEMA=public

# =========================================
# OLLAMA CHAT / CLOUD
# =========================================
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=YOUR_OLLAMA_API_KEY
OLLAMA_CHAT_MODEL=gpt-oss:20b-cloud
FACT_EXTRACTION_MODEL=gpt-oss:20b-cloud
WIKI_GENERATION_MODEL=gpt-oss:20b-cloud
QA_GENERATION_MODEL=gpt-oss:20b-cloud
OLLAMA_NUM_CTX=32768
OLLAMA_TIMEOUT=180

# =========================================
# EMBEDDINGS
# Option A: use same Ollama base URL
# Option B recommended: local embedding server
# =========================================
OLLAMA_EMBED_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_API_KEY=
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# =========================================
# AUTH
# =========================================
# SECURITY: Replace with a strong random secret before deploying.
#   Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   Leave empty to disable authentication entirely (development only).
API_KEY=YOUR_STRONG_SECRET_HERE
API_KEY_ENABLED=true

# =========================================
# CRAWLER
# =========================================
# Options: trafilatura | playwright | crawl4ai
#   trafilatura = fast, no browser, static HTML only (default)
#   playwright  = headless Chromium, renders JS  (needs: playwright install chromium)
#   crawl4ai    = LLM-aware + JS rendering, best quality (needs: patchright install chromium)
CRAWLER_BACKEND=trafilatura

# =========================================
# COMPANY / RETRIEVAL
# =========================================
DEFAULT_COMPANY_CODE=DEVES
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
CANONICAL_THRESHOLD=0.90
ANSWER_CACHE_THRESHOLD=0.96
SIMILARITY_THRESHOLD=0.35

# =========================================
# DETERMINISTIC AI
# =========================================
TEMPERATURE=0
TOP_P=0.1
TOP_K=1
SEED=42

# =========================================
# FEATURES
# =========================================
ENABLE_CANONICAL_QA=true
ENABLE_ANSWER_CACHE=true
ENABLE_WIKI_SEARCH=true
ENABLE_CHUNK_SEARCH=true
ENABLE_RERANKER=false
ENABLE_QUERY_REWRITE=false
ENABLE_GROUNDING=true
ENABLE_RELATIONSHIP_SEARCH=true
ENABLE_METADATA_SEARCH=true

# =========================================
# JOBS / SCHEDULER
# =========================================
ENABLE_SCHEDULER=true
DAILY_CRAWL_CRON_HOUR=2
DAILY_CRAWL_CRON_MINUTE=0

# =========================================
# CACHE / LOGGING
# =========================================
CACHE_TTL_SECONDS=86400
# Set to "WARNING" or "ERROR" in production to reduce log volume
LOG_LEVEL=INFO
