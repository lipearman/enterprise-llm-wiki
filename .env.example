# =========================================
# APP
# =========================================
APP_NAME=Enterprise LLM Wiki
APP_ENV=development
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080
API_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000
ALLOW_ORIGINS=*

# =========================================
# SUPABASE CLOUD
# =========================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SCHEMA=public

# =========================================
# OLLAMA CHAT / CLOUD
# =========================================
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=YOUR_OLLAMA_API_KEY
OLLAMA_CHAT_MODEL=gpt-oss:20b-cloud
FACT_EXTRACTION_MODEL=gpt-oss:20b-cloud
WIKI_GENERATION_MODEL=gpt-oss:20b-cloud
QA_GENERATION_MODEL=gpt-oss:20b-cloud
OLLAMA_NUM_CTX=32768
OLLAMA_TIMEOUT=180

# =========================================
# EMBEDDINGS
# Option A: use same Ollama base URL
# Option B recommended: local embedding server
# =========================================
OLLAMA_EMBED_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_API_KEY=
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# =========================================
# COMPANY / RETRIEVAL
# =========================================
DEFAULT_COMPANY_CODE=LOCKTON
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
CANONICAL_THRESHOLD=0.90
ANSWER_CACHE_THRESHOLD=0.96
SIMILARITY_THRESHOLD=0.35

# =========================================
# DETERMINISTIC AI
# =========================================
TEMPERATURE=0
TOP_P=0.1
TOP_K=1
SEED=42

# =========================================
# FEATURES
# =========================================
ENABLE_CANONICAL_QA=true
ENABLE_ANSWER_CACHE=true
ENABLE_WIKI_SEARCH=true
ENABLE_CHUNK_SEARCH=true
ENABLE_RERANKER=false
ENABLE_QUERY_REWRITE=false
ENABLE_GROUNDING=true
ENABLE_RELATIONSHIP_SEARCH=false
ENABLE_METADATA_SEARCH=true

# =========================================
# JOBS
# =========================================
ENABLE_SCHEDULER=true
DAILY_CRAWL_CRON_HOUR=2
DAILY_CRAWL_CRON_MINUTE=0

# =========================================
# CACHE / LOGGING
# =========================================
CACHE_TTL_SECONDS=86400
LOG_LEVEL=INFO
